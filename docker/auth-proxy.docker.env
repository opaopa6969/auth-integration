# volta-auth-proxy — docker-compose 用の上書き env
#
# 秘密 (JWT 鍵 / secret) は dev/auth-proxy-dev.env からそのまま流用する。
# このファイルは「docker network 向けに書き換える非秘密の値」だけを持ち、
# compose の env_file で dev/auth-proxy-dev.env の後に読ませて上書きする。
#
# → git に commit して良い (秘密を含まない)。

# コンテナ内の listen port。auth-proxy の Dockerfile は 27070 を EXPOSE。
PORT=27070

# DB は docker service 名で解決。ホストの :25432 ではなくコンテナ内 25432。
DB_HOST=postgres
DB_PORT=25432
DB_NAME=volta_auth
DB_USER=volta
DB_PASSWORD=volta

# 入口は gateway。Magic Link / redirect の URL はここ基準で生成される。
BASE_URL=http://localhost:28888
ALLOWED_REDIRECT_DOMAINS=localhost,127.0.0.1

# apps 定義はマウント先の絶対パスへ。
APP_CONFIG_PATH=/app/volta-config.yaml

# DEV_MODE は dev env でも true。Magic Link の token/link を response に返す。
DEV_MODE=true

# 全リクエスト anonymous 通過を防ぐため空に固定。
LOCAL_BYPASS_CIDRS=

# auth イベント / telemetry publish 先 (service 名で解決)。
REDIS_URL=redis://redis:26379

# 通知は mailpit (SMTP catcher) へ。DEV_MODE なら response にも link が返る。
NOTIFICATION_CHANNEL=smtp
SMTP_HOST=mailpit
SMTP_PORT=21025
SMTP_FROM=volta-dev@example.com
