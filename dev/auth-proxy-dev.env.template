# Copy this file to auth-proxy-dev.env and fill in values.
# 11-本物auth-proxy起動.md の手順で生成する。

PORT=27070                            # 既存ポートと衝突しない新ポート (host listen 用)
DB_HOST=localhost
DB_PORT=25432                        # docker run -p 25432:25432 で立てた dev Postgres
DB_NAME=volta_auth
DB_USER=volta
DB_PASSWORD=volta
BASE_URL=http://localhost:27070
JWT_ISSUER=volta-auth-dev
JWT_AUDIENCE=volta-apps-dev

# openssl genrsa -out jwt-private.pem 2048 で生成 → awk '{printf "%s\\n", $0}' で改行をエスケープ
JWT_PRIVATE_KEY_PEM="<dev/jwt-private.pem の中身を \\n エスケープで>"
JWT_PUBLIC_KEY_PEM="<dev/jwt-public.pem の中身を \\n エスケープで>"

JWT_TTL_SECONDS=300
SESSION_TTL_SECONDS=28800

# openssl rand -hex 32 で生成 → dev/jwt-key-encryption-secret.txt
JWT_KEY_ENCRYPTION_SECRET=<32バイトのhex>

ALLOWED_REDIRECT_DOMAINS=localhost,127.0.0.1

# openssl rand -hex 16 で生成 → dev/volta-service-token.txt
VOLTA_SERVICE_TOKEN=<16バイトのhex>

DEV_MODE=true                        # Magic Link の token/link を response に返す
LOCAL_BYPASS_CIDRS=                  # 空にしないと 127.0.0.1 からのリクエストが anonymous で通る

APP_CONFIG_PATH=dev/volta-config-dev.yaml
NOTIFICATION_CHANNEL=none            # メール送らない (DEV_MODE で link 取れるので不要)
WEBHOOK_ENABLED=false
AUDIT_SINK=postgres
